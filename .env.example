# =============================================================================
# tpt-healthcare-nz — environment variable reference
#
# Copy this file to .env and fill in values for your environment.
# Never commit .env to version control.
#
# For NHI, HPI, NES, and ACC: always use UAT/sandbox endpoints during
# development. Never use production credentials on a developer machine.
# =============================================================================


# =============================================================================
# Database (required)
# =============================================================================

# pgx-format PostgreSQL connection string.
# Local dev default matches deploy/docker-compose.dev.yml.
DATABASE_URL=postgres://tpt:tpt@localhost:5432/tpt_healthcare_dev

# Connection pool tuning (optional — defaults applied in code).
# DB_MAX_CONNS=25
# DB_MIN_CONNS=2


# =============================================================================
# Redis (required)
# =============================================================================

REDIS_URL=redis://localhost:6379


# =============================================================================
# Encryption (required)
# =============================================================================

# 32-byte AES-256-GCM key, base64-encoded. Used for all PHI field encryption.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=


# =============================================================================
# Interop server
# =============================================================================

PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Token-bucket rate limit (requests/second per client IP).
RATE_LIMIT=100

# Advertise on the local network via mDNS-SD (tpt-interop.local).
# Set to true in a clinic LAN environment.
MDNS=false


# =============================================================================
# Authentication
# =============================================================================

# --- Auth0 (optional — use if deploying with Auth0) ---
# AUTH0_DOMAIN=your-tenant.au.auth0.com
# AUTH0_AUDIENCE=https://api.tpt.nz

# --- Ed25519 JWT (optional — use if deploying with the built-in JWT provider) ---
# Path to a PEM-encoded Ed25519 private key. Generate with:
#   openssl genpkey -algorithm ed25519 -out jwt_private.pem
# JWT_PRIVATE_KEY_PATH=./jwt_private.pem

# TOTP issuer label shown in authenticator apps.
# TOTP_ISSUER=TPT Healthcare


# =============================================================================
# NHI — National Health Index (Te Whatu Ora)
# Use the UAT endpoint during development.
# =============================================================================

NHI_BASE_URL=https://api.uat.digital.health.nz/nhi-v2
NHI_CLIENT_ID=
NHI_CLIENT_SECRET=
# NHI SMART on FHIR token endpoint (usually auto-discovered from the base URL).
# NHI_TOKEN_URL=


# =============================================================================
# HPI — Health Practitioner Index (Te Whatu Ora)
# =============================================================================

HPI_BASE_URL=https://api.uat.digital.health.nz/hpi
HPI_CLIENT_ID=
HPI_CLIENT_SECRET=
# APC validation cache TTL in seconds (default 86400 = 24 hours).
# HPI_CACHE_TTL=86400


# =============================================================================
# NES — National Enrolment Service (Te Whatu Ora)
# =============================================================================

NES_BASE_URL=https://api.uat.digital.health.nz/nes
NES_CLIENT_ID=
NES_CLIENT_SECRET=


# =============================================================================
# ACC — Accident Compensation Corporation
# =============================================================================

ACC_BASE_URL=https://api.uat.acc.co.nz/claims
ACC_CLIENT_ID=
ACC_CLIENT_SECRET=
# Polling interval for ClaimResponse status updates, in seconds.
# ACC_POLL_INTERVAL=60


# =============================================================================
# PHARMAC formulary
# =============================================================================

PHARMAC_BASE_URL=https://www.pharmac.govt.nz/api/v1
# PHARMAC_API_KEY=


# =============================================================================
# HL7 v2 MLLP listener
# =============================================================================

# TCP address for the MLLP listener. Leave empty to disable.
# MLLP_ADDR=0.0.0.0:2575


# =============================================================================
# Email (choose one provider)
# =============================================================================

# EMAIL_PROVIDER=sendgrid  # sendgrid | mailgun | mailjet | postmark | ses

# SendGrid
# SENDGRID_API_KEY=

# Mailgun
# MAILGUN_DOMAIN=
# MAILGUN_API_KEY=

# Mailjet
# MAILJET_API_KEY=
# MAILJET_SECRET_KEY=

# Postmark
# POSTMARK_SERVER_TOKEN=

# AWS SES
# AWS_SES_REGION=ap-southeast-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=


# =============================================================================
# SMS (choose one provider)
# =============================================================================

# SMS_PROVIDER=twilio  # twilio | vonage | burstsms | messagebird

# Twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# Vonage / Nexmo
# VONAGE_API_KEY=
# VONAGE_API_SECRET=

# Burst SMS (NZ)
# BURSTSMS_API_KEY=
# BURSTSMS_API_SECRET=


# =============================================================================
# Storage (choose one provider)
# =============================================================================

# STORAGE_PROVIDER=s3  # s3 | azblob | minio | wasabi

# AWS S3
# AWS_S3_BUCKET=
# AWS_S3_REGION=ap-southeast-2

# Azure Blob Storage
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_KEY=
# AZURE_STORAGE_CONTAINER=

# MinIO (local dev / self-hosted)
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=tpt-healthcare
# MINIO_USE_SSL=false


# =============================================================================
# Payment (choose one provider)
# =============================================================================

# PAYMENT_PROVIDER=windcave  # windcave | paymark | eway | stripe | humm | poli

# Windcave (NZ — recommended)
# WINDCAVE_API_KEY=
# WINDCAVE_API_USER=

# Paymark (NZ)
# PAYMARK_CLIENT_ID=
# PAYMARK_CLIENT_SECRET=

# Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=


# =============================================================================
# Video (choose one provider)
# =============================================================================

# VIDEO_PROVIDER=zoom  # zoom | teams | jitsi

# Zoom
# ZOOM_ACCOUNT_ID=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=

# Jitsi (self-hosted)
# JITSI_BASE_URL=https://meet.jit.si
# JITSI_APP_ID=
# JITSI_APP_SECRET=


# =============================================================================
# Payroll (choose one provider — for practice HR features)
# =============================================================================

# PAYROLL_PROVIDER=payhero  # payhero | ipayroll | datacom | flexitime

# PayHero (NZ)
# PAYHERO_API_KEY=

# iPayroll (NZ)
# IPAYROLL_CLIENT_ID=
# IPAYROLL_CLIENT_SECRET=


# =============================================================================
# Observability
# =============================================================================

# OpenTelemetry OTLP exporter endpoint (leave empty to disable tracing).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=tpt-health-interop

# Prometheus metrics are exposed at /metrics automatically.
# No additional config required for local development.
